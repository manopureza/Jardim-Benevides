<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Story — Jardim Benevides</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&family=Oswald:wght@300;400;700&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: #111;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  font-family: 'Montserrat', sans-serif;
}

/* STORY FRAME: 9:16 */
.story {
  width: 390px;
  height: 693px;
  position: relative;
  overflow: hidden;
  border-radius: 18px;
  background: #0a0a0a;
  box-shadow: 0 40px 120px rgba(0,0,0,0.8);
}

/* ── FUNDO 3D ── */
.bg-scene {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, #0d1f0d 0%, #050f05 50%, #000 100%);
  perspective: 600px;
}

/* Grade de chão isométrica */
.grid-floor {
  position: absolute;
  bottom: -20px;
  left: 50%;
  transform: translateX(-50%) rotateX(60deg) rotateZ(0deg);
  width: 600px;
  height: 500px;
  background-image:
    linear-gradient(rgba(245,166,35,0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(245,166,35,0.08) 1px, transparent 1px);
  background-size: 40px 40px;
  transform-origin: bottom center;
  animation: gridPulse 4s ease-in-out infinite;
}
@keyframes gridPulse {
  0%,100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* Partículas douradas */
.particles {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.p {
  position: absolute;
  border-radius: 50%;
  background: var(--ouro, #f5a623);
  animation: floatUp var(--d, 4s) var(--delay, 0s) ease-in-out infinite;
  opacity: 0;
}
@keyframes floatUp {
  0% { transform: translateY(0) scale(1); opacity: 0; }
  20% { opacity: 0.7; }
  100% { transform: translateY(-200px) scale(0.3); opacity: 0; }
}

/* Esferas 3D decorativas */
.sphere {
  position: absolute;
  border-radius: 50%;
  filter: blur(0.5px);
}
.sphere-1 {
  width: 120px; height: 120px;
  top: -30px; right: -30px;
  background: radial-gradient(circle at 35% 35%,
    rgba(245,166,35,0.35) 0%,
    rgba(180,100,0,0.2) 50%,
    rgba(0,0,0,0.4) 100%);
  box-shadow: inset -8px -8px 20px rgba(0,0,0,0.6), 0 0 40px rgba(245,166,35,0.15);
  animation: sphereFloat 6s ease-in-out infinite;
}
.sphere-2 {
  width: 70px; height: 70px;
  bottom: 80px; left: -15px;
  background: radial-gradient(circle at 35% 35%,
    rgba(245,166,35,0.2) 0%,
    rgba(100,60,0,0.15) 50%,
    rgba(0,0,0,0.5) 100%);
  box-shadow: inset -4px -4px 12px rgba(0,0,0,0.5), 0 0 20px rgba(245,166,35,0.1);
  animation: sphereFloat 8s ease-in-out infinite reverse;
}
@keyframes sphereFloat {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

/* ── CONTEÚDO ── */
.content {
  position: relative;
  z-index: 10;
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 28px 24px 24px;
}

/* TOPO */
.top-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  animation: fadeDown 0.6s ease both;
}
.badge-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #f5a623;
  box-shadow: 0 0 8px #f5a623;
  animation: blink 1.5s ease-in-out infinite;
}
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.3;} }
.badge-text {
  font-family: 'Oswald', sans-serif;
  font-size: 0.62rem;
  letter-spacing: 3px;
  color: #f5a623;
  text-transform: uppercase;
  font-weight: 400;
}

/* LOGO / TÍTULO */
.title-block {
  margin-top: 18px;
  animation: fadeDown 0.6s 0.1s ease both;
}
.title-eyebrow {
  font-size: 0.58rem;
  letter-spacing: 4px;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  margin-bottom: 4px;
}
.title-main {
  font-family: 'Oswald', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.title-main span {
  color: #f5a623;
  text-shadow: 0 0 20px rgba(245,166,35,0.5);
}

/* HERO STAT - UNIDADES */
.hero-stat {
  margin-top: auto;
  animation: fadeUp 0.7s 0.2s ease both;
}

/* 3D CARD PRINCIPAL */
.card-3d {
  background: linear-gradient(135deg,
    rgba(255,255,255,0.07) 0%,
    rgba(255,255,255,0.02) 100%);
  border: 1px solid rgba(245,166,35,0.25);
  border-radius: 16px;
  padding: 20px 22px;
  position: relative;
  overflow: hidden;
  transform: perspective(800px) rotateX(3deg);
  box-shadow:
    0 20px 60px rgba(0,0,0,0.5),
    0 0 0 1px rgba(255,255,255,0.04),
    inset 0 1px 0 rgba(255,255,255,0.1);
  animation: cardReveal 0.8s 0.3s ease both;
}
.card-3d::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(245,166,35,0.6), transparent);
}
.card-3d::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(245,166,35,0.04) 0%, transparent 60%);
  pointer-events: none;
}

@keyframes cardReveal {
  from { opacity:0; transform: perspective(800px) rotateX(12deg) translateY(20px); }
  to   { opacity:1; transform: perspective(800px) rotateX(3deg) translateY(0); }
}

.card-label-top {
  font-size: 0.6rem;
  letter-spacing: 3px;
  color: rgba(255,255,255,0.35);
  text-transform: uppercase;
  margin-bottom: 10px;
}

.units-row {
  display: flex;
  align-items: flex-end;
  gap: 6px;
  margin-bottom: 14px;
}
.units-num {
  font-family: 'Oswald', sans-serif;
  font-size: 4.5rem;
  font-weight: 700;
  line-height: 1;
  color: #f5a623;
  text-shadow: 0 0 40px rgba(245,166,35,0.4), 0 4px 20px rgba(0,0,0,0.5);
  letter-spacing: -1px;
}
.units-suffix {
  font-family: 'Oswald', sans-serif;
  font-size: 1.1rem;
  color: rgba(255,255,255,0.5);
  margin-bottom: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
}

/* BARRA VISUAL */
.unit-bar {
  display: flex;
  gap: 3px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}
.unit-dot {
  width: 10px; height: 10px;
  border-radius: 3px;
}
.unit-dot.vendida { background: #e03c2b; box-shadow: 0 0 6px rgba(224,60,43,0.5); }
.unit-dot.reservada { background: #f5a623; box-shadow: 0 0 4px rgba(245,166,35,0.4); }
.unit-dot.disponivel { background: rgba(255,255,255,0.12); }

.bar-legend {
  display: flex;
  gap: 14px;
}
.bl-item {
  display: flex;
  align-items: center;
  gap: 5px;
}
.bl-dot {
  width: 7px; height: 7px;
  border-radius: 2px;
}
.bl-text {
  font-size: 0.6rem;
  color: rgba(255,255,255,0.45);
  letter-spacing: 1px;
  text-transform: uppercase;
}

/* DIVISOR */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(245,166,35,0.2), transparent);
  margin: 14px 0;
}

/* STATS MINI */
.mini-stats {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px;
  animation: fadeUp 0.7s 0.45s ease both;
}
.mstat {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 10px;
  padding: 10px 8px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.mstat::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
}
.mstat.s1::before { background: #e03c2b; }
.mstat.s2::before { background: #f5a623; }
.mstat.s3::before { background: #4caf50; }
.mstat-val {
  font-family: 'Oswald', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  line-height: 1;
}
.mstat.s1 .mstat-val { color: #e03c2b; }
.mstat.s2 .mstat-val { color: #f5a623; }
.mstat.s3 .mstat-val { color: #4caf50; }
.mstat-label {
  font-size: 0.55rem;
  color: rgba(255,255,255,0.35);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-top: 3px;
}

/* MENSAGEM CENTRAL */
.msg-block {
  margin-top: 14px;
  text-align: center;
  animation: fadeUp 0.7s 0.55s ease both;
}
.msg-line1 {
  font-family: 'Oswald', sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2px;
  text-transform: uppercase;
}
.msg-line2 {
  font-size: 0.68rem;
  color: rgba(255,255,255,0.4);
  margin-top: 4px;
  letter-spacing: 1px;
}

/* CTA BOTTOM */
.cta-block {
  margin-top: 14px;
  animation: fadeUp 0.7s 0.65s ease both;
}
.cta-bar {
  background: linear-gradient(90deg, #f5a623, #e8920a);
  border-radius: 10px;
  padding: 13px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8px 30px rgba(245,166,35,0.35), 0 2px 8px rgba(0,0,0,0.4);
  position: relative;
  overflow: hidden;
}
.cta-bar::before {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
  animation: shine 2.5s ease-in-out infinite;
}
@keyframes shine {
  0% { left: -100%; }
  100% { left: 200%; }
}
.cta-text-wrap { line-height: 1; }
.cta-small {
  font-size: 0.58rem;
  letter-spacing: 2px;
  color: rgba(0,0,0,0.5);
  text-transform: uppercase;
}
.cta-big {
  font-family: 'Oswald', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: #000;
  letter-spacing: 1px;
  text-transform: uppercase;
}
.cta-arrow {
  font-size: 1.2rem;
  color: rgba(0,0,0,0.6);
  animation: arrowBounce 1s ease-in-out infinite;
}
@keyframes arrowBounce {
  0%,100% { transform: translateX(0); }
  50% { transform: translateX(4px); }
}

/* RODAPÉ */
.footer {
  margin-top: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  animation: fadeUp 0.7s 0.75s ease both;
}
.footer-brand {
  font-family: 'Oswald', sans-serif;
  font-size: 0.72rem;
  letter-spacing: 2px;
  color: rgba(255,255,255,0.25);
  text-transform: uppercase;
}
.footer-creci {
  font-size: 0.55rem;
  color: rgba(255,255,255,0.2);
  letter-spacing: 1px;
}

/* ANIMAÇÕES GLOBAIS */
@keyframes fadeDown {
  from { opacity:0; transform: translateY(-12px); }
  to { opacity:1; transform: translateY(0); }
}
@keyframes fadeUp {
  from { opacity:0; transform: translateY(14px); }
  to { opacity:1; transform: translateY(0); }
}

/* SCANLINES sutil */
.scanlines {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,0.03) 2px,
    rgba(0,0,0,0.03) 4px
  );
  pointer-events: none;
  z-index: 5;
}

/* VINHETA */
.vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.7) 100%);
  pointer-events: none;
  z-index: 6;
}
</style>
</head>
<body>

<div class="story">

  <!-- FUNDO 3D -->
  <div class="bg-scene">
    <div class="grid-floor"></div>
  </div>

  <!-- ESFERAS -->
  <div class="sphere sphere-1"></div>
  <div class="sphere sphere-2"></div>

  <!-- PARTÍCULAS -->
  <div class="particles" id="particles"></div>

  <!-- OVERLAY TEXTURAS -->
  <div class="scanlines"></div>
  <div class="vignette"></div>

  <!-- CONTEÚDO -->
  <div class="content">

    <!-- TOPO -->
    <div class="top-badge">
      <div class="badge-dot"></div>
      <div class="badge-text">Atualização de estoque · Jardim Benevides</div>
    </div>

    <div class="title-block">
      <div class="title-eyebrow">Condomínio Residencial</div>
      <div class="title-main">Quem decide<br><span>primeiro</span><br>leva mais.</div>
    </div>

    <!-- CARD PRINCIPAL 3D -->
    <div class="hero-stat">
      <div class="card-3d">
        <div class="card-label-top">Unidades já comprometidas</div>

        <div class="units-row">
          <div class="units-num">39</div>
          <div class="units-suffix">de 264</div>
        </div>

        <!-- DOTS VISUAIS -->
        <div class="unit-bar" id="unitBar"></div>

        <div class="bar-legend">
          <div class="bl-item">
            <div class="bl-dot" style="background:#e03c2b"></div>
            <span class="bl-text">Vendidas</span>
          </div>
          <div class="bl-item">
            <div class="bl-dot" style="background:#f5a623"></div>
            <span class="bl-text">Reservadas</span>
          </div>
          <div class="bl-item">
            <div class="bl-dot" style="background:rgba(255,255,255,0.12)"></div>
            <span class="bl-text">Disponíveis</span>
          </div>
        </div>
      </div>
    </div>

    <!-- MINI STATS -->
    <div class="mini-stats" style="margin-top:14px">
      <div class="mstat s1">
        <div class="mstat-val">3</div>
        <div class="mstat-label">Vendidas</div>
      </div>
      <div class="mstat s2">
        <div class="mstat-val">36</div>
        <div class="mstat-label">Reservadas</div>
      </div>
      <div class="mstat s3">
        <div class="mstat-val">186</div>
        <div class="mstat-label">Livres*</div>
      </div>
    </div>

    <!-- MENSAGEM -->
    <div class="msg-block">
      <div class="msg-line1">Melhores unidades saem primeiro</div>
      <div class="msg-line2">térreo · posição · orientação solar</div>
    </div>

    <!-- CTA -->
    <div class="cta-block">
      <div class="cta-bar">
        <div class="cta-text-wrap">
          <div class="cta-small">Garanta a sua agora</div>
          <div class="cta-big">Fale comigo hoje</div>
        </div>
        <div class="cta-arrow">→</div>
      </div>
    </div>

    <!-- RODAPÉ -->
    <div class="footer">
      <div class="footer-brand">GP Imóveis · Gabriel Pureza</div>
      <div class="footer-creci">CRECI-PA 14.122</div>
    </div>

  </div><!-- /content -->
</div><!-- /story -->

<script>
// Gerar dots visuais de unidades
const bar = document.getElementById('unitBar');
const total = 48; // dots representativos
const vendidas = 2;
const reservadas = 7;
for (let i = 0; i < total; i++) {
  const d = document.createElement('div');
  d.className = 'unit-dot';
  if (i < vendidas) d.classList.add('vendida');
  else if (i < vendidas + reservadas) d.classList.add('reservada');
  else d.classList.add('disponivel');
  bar.appendChild(d);
}

// Partículas
const pWrap = document.getElementById('particles');
for (let i = 0; i < 18; i++) {
  const p = document.createElement('div');
  p.className = 'p';
  const size = Math.random() * 3 + 1.5;
  p.style.cssText = `
    width:${size}px; height:${size}px;
    left:${Math.random()*100}%;
    bottom:${Math.random()*40}%;
    --d:${3+Math.random()*5}s;
    --delay:${Math.random()*4}s;
    --ouro:#f5a623;
  `;
  pWrap.appendChild(p);
}
</script>
</body>
</html>